# Neon Postgres (shared with the Django backend)
# Use the pooled connection string for serverless.
DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler.REGION.aws.neon.tech/DB?sslmode=require"

# Auth.js v5 — generate with: openssl rand -base64 32
# (or: pnpm dlx auth secret)
AUTH_SECRET="replace-with-random-32-byte-base64"

# Set to the dev URL locally. Auth.js infers it in production from Vercel/Next env.
AUTH_URL="http://localhost:5175"

# Cloudinary (same account as the Django backend). Optional — image
# upload fields fall back to an error toast if these are unset.
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"
CLOUDINARY_FOLDER="ar-e-admin"
